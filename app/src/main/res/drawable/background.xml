<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#211D1D"
                android:endColor="#211D1D"
                android:angle="90"/>
            <corners android:radius="0dp"/>
            <stroke
                android:width="2dp"
                android:color="#211D1D"/>
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#211D1D"
                android:centerColor="#211D1D"
                android:endColor="#211D1D"
                android:angle="90"/>
            <corners android:radius="0dp"/>
            <stroke
                android:width="2dp"
                android:color="#211D1D"/>
        </shape>
    </item>

</selector>